{
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(node *)",
      "Bash(rm *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash(git commit *)",
        "command": "npx gitnexus analyze"
      },
      {
        "matcher": "Bash(git merge *)",
        "command": "npx gitnexus analyze"
      }
    ]
  }
}
